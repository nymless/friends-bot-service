# Copy to .env.k6 alongside .env.load
#
# k6-only tuning — no stack restart. Change anything here, then make load-k6*.
# Bot/chat IDs must match .env.load (LOAD_BOT_* / LOAD_CHAT_* / LOAD_USER_*).

# --- Ramp: command (make load-k6-ramp*) ---
# /stats — no draw entrants; /run or /loser — set LOAD_SEED_DRAW_ENTRANTS=true in .env.load
LOAD_K6_COMMAND=/run

# --- Ramp: load shape (make load-k6-ramp*) ---
# Bot pick: vu (default) = sticky per virtual user (VU); random = new bot each request
LOAD_RAMP_BOT_PICK=vu
# Peak requests per second (RPS) on plateau — sustained load (all VUs combined)
LOAD_RAMP_RPS_PEAK=50
LOAD_RAMP_STAGE_RAMP_UP=30s
LOAD_RAMP_STAGE_PLATEAU=1m
LOAD_RAMP_STAGE_RAMP_DOWN=30s
# Optional (defaults derived from LOAD_RAMP_RPS_PEAK — see load/k6/env_common.js):
# LOAD_RAMP_RPS_START=10
# LOAD_RAMP_RPS_END=10
# LOAD_RAMP_MAX_VUS=100
# LOAD_RAMP_PREALLOCATED_VUS=20

# --- Happy-path (make load-k6-run*) ---
# One successful /run per bot; VUs default to LOAD_BOT_COUNT
LOAD_RUN_HAPPY_MAX_DURATION=10m
# LOAD_RUN_HAPPY_VUS=100

# --- Contention (make load-k6-run-contention*) ---
# Parallel /run on one bot/chat
LOAD_CONTENTION_VUS=20
LOAD_CONTENTION_ITERATIONS=50
LOAD_CONTENTION_MAX_DURATION=10m
# Optional: pin bot/chat (default LOAD_BOT_ID_START)
# LOAD_CONTENTION_BOT_ID=1000000
