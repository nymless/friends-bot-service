# Copy to .env.k6 alongside .env.load
#
# k6-only tuning — no stack restart. Change anything here, then make load-k6*.
# Bot/chat IDs must match .env.load (LOAD_BOT_* / LOAD_CHAT_* / LOAD_USER_*).

# Draw command for run profiles: /run or /loser
LOAD_DRAW_COMMAND=/run

# Contention profile (one bot/chat, parallel /run)
LOAD_CONTENTION_VUS=20
LOAD_CONTENTION_ITERATIONS=50
LOAD_CONTENTION_MAX_DURATION=10m
# Optional override: which bot/chat all contention VUs hit (default LOAD_BOT_ID_START).
# Seeded bots are identical — leave unset for normal AB runs. Set only to pin a bot_id
# in logs/Prometheus or when debugging one chat after a partial/manual experiment.
# LOAD_CONTENTION_BOT_ID=1000000

# k6 /stats ramp (make load-k6 / load-k6-polling): synthetic /stats, ramping-arrival-rate executor
# Peak RPS on plateau — target sustained /stats requests per second (all VUs combined)
LOAD_STATS_RPS_PEAK=50
# RPS at run start (ramp-up begins here); optional — default round(LOAD_STATS_RPS_PEAK / 5) → 10 when peak=50
# LOAD_STATS_RPS_START=10
# RPS after ramp-down (run ends here); optional — default round(LOAD_STATS_RPS_PEAK / 5) → 10 when peak=50
# LOAD_STATS_RPS_END=10
# Wall-clock time to ramp from START (or default) up to PEAK
LOAD_STATS_STAGE_RAMP_UP=30s
# Wall-clock time holding PEAK before ramp-down
LOAD_STATS_STAGE_PLATEAU=1m
# Wall-clock time to ramp from PEAK down to END (or default)
LOAD_STATS_STAGE_RAMP_DOWN=30s
# Max k6 VUs for this scenario; optional — default max(LOAD_BOT_COUNT, LOAD_STATS_RPS_PEAK, 100) → 100 here
# LOAD_STATS_MAX_VUS=100
# VUs k6 reserves at startup; optional — default min(20, LOAD_STATS_MAX_VUS or its default) → 20 here
# LOAD_STATS_PREALLOCATED_VUS=20

# k6 happy-path /run (make load-k6-run*); VUs default to LOAD_BOT_COUNT
LOAD_RUN_HAPPY_MAX_DURATION=10m
# LOAD_RUN_HAPPY_VUS=100
