# Bot mode: "polling" or "webhook"
BOT_MODE="polling"

# Uvicorn worker count for "webhook" mode (each worker has its own DB pool)
WORKER_COUNT=1

# Prometheus scrape endpoint (both modes; see ADR 0005)
METRICS_BIND_HOST=127.0.0.1
METRICS_BIND_PORT=8001

# SQLAlchemy config (pool is per process; see README "Database connection budget")
DB_URL="postgresql+asyncpg://user:pass@localhost/dbname"
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Secret key for bot token encription
ENCRYPTION_KEY="YOUR_SECRET_KEY"

# Master bot token
MASTER_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Webhook base URL
WEBHOOK_BASE_URL="https://example.com"

# Webhook secret token
WEBHOOK_SECRET_TOKEN="your_webhook_secret_token"

# Optional: route Bot API calls to a mock (load tests). Unset in production.
# TELEGRAM_API_BASE_URL=http://telegram-mock:8081

# Allow new draw entrant and bot registrations
REGISTRATION_ENABLED=true

# Log inbound slash-commands as access log (upd, bot, chat, user, command text)
LOG_INBOUND_COMMANDS=false
