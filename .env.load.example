# Copy to .env.load and .env.k6.example → .env.k6
#
# Scenarios and metrics: docs/load-runbook.md, docs/adr/0003-load-testing-multi-worker-webhook.md
#
#   Clean run:  make load-down-v load-up → wait in logs → make load-seed load-restart
#   .env.k6 only: make load-k6*
#   New code:   make load-build, then clean run above

# --- Docker image ---
# Rebuild after code change: make docker-build load-build
APP_IMAGE=friends-bot-service:local

# --- Simulation mode (change → load-down-v load-up → seed → restart) ---
# webhook — NGINX_ENABLED=1, BOT_MODE=webhook (HTTP callbacks from Telegram mock)
# polling — NGINX_ENABLED=0, BOT_MODE=polling (long-polling getUpdates)
NGINX_ENABLED=1
BOT_MODE=webhook
# App worker processes in vps-sim (default 1). Multiple workers: see ADR 0003.
WORKER_COUNT=1

# --- vps-sim resource limits ---
VPS_SIM_CPUS=1
VPS_SIM_MEMORY=2g

# --- Host ports (compose.load.yml) ---
LOAD_HTTP_PORT=8080
LOAD_APP_PORT=8000
# Metrics scrape target: Makefile METRICS_PORT (default 8001), SCRAPE_INTERVAL (default 15s)

# --- App secrets & webhook (fill before first run) ---
ENCRYPTION_KEY=change-me-32-bytes-min-secret!!
MASTER_TOKEN=0000000000:REPLACE_WITH_MASTER_BOT_TOKEN
WEBHOOK_BASE_URL=http://localhost:8080
WEBHOOK_SECRET_TOKEN=load-test-webhook-secret
# Game bots → telegram-mock (set in compose.load.yml). Master bot unchanged.
TELEGRAM_API_BASE_URL=http://telegram-mock:8081

# --- App runtime ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
REGISTRATION_ENABLED=true
LOG_INBOUND_COMMANDS=false

# --- Seed: bot count and draw players (change → load-seed load-restart) ---
LOAD_BOT_COUNT=100
# false — ramp /stats (bots table only); true — draw (/run, /loser) or make load-k6-run*
LOAD_SEED_DRAW_ENTRANTS=false
# Required when LOAD_SEED_DRAW_ENTRANTS=true (>=2 for /run then /loser in same chat)
LOAD_PLAYERS_PER_CHAT=2

# --- Seed: technical IDs (shared with k6; usually leave unchanged) ---
LOAD_BOT_ID_START=1000000
LOAD_BOT_OWNER_ID=1
LOAD_CHAT_ID_BASE=10000000
LOAD_USER_ID_BASE=100000

# --- PostgreSQL inside vps-sim (do not change; DB_URL derived in compose.load.yml) ---
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_DB=friends_bot
