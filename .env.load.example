# Copy to .env.load and .env.k6.example → .env.k6
#
#   Clean run:  make load-down-v load-up → wait in logs → make load-seed load-restart
#   .env.k6:    make load-k6*
#   New code:   make load-build, then clean run above
#
# --- AB-1 webhook: main (registry) vs feature/workers (db-first ingress) ---
#   NGINX_ENABLED=1, BOT_MODE=webhook
#   make load-k6 / load-k6-run / load-k6-run-contention
#   Baseline on main; repeat on workers after merging load stack
#
# --- AB-2 polling: main (lock) vs feature/workers (claim) ---
#   NGINX_ENABLED=0, BOT_MODE=polling
#   make load-k6-polling / load-k6-run-polling / load-k6-run-contention-polling (all three)
#   Happy-path /run: claim DB overhead; contention: race safety check
#
# Image tag: rebuild after branch switch (make docker-build IMAGE=... load-build)
APP_IMAGE=friends-bot-service:local

NGINX_ENABLED=1
BOT_MODE=webhook

# Ignored on main; used on feature/workers for multi-process webhook (ADR 0003)
WORKER_COUNT=1

VPS_SIM_CPUS=1
VPS_SIM_MEMORY=2g

ENCRYPTION_KEY=change-me-32-bytes-min-secret!!
MASTER_TOKEN=0000000000:REPLACE_WITH_MASTER_BOT_TOKEN
WEBHOOK_BASE_URL=http://localhost:8080
WEBHOOK_SECRET_TOKEN=load-test-webhook-secret

# Game bots use telegram-mock (set in compose.load.yml). Master bot is unchanged.
TELEGRAM_API_BASE_URL=http://telegram-mock:8081

# Load test parameters (adjust per run)
LOAD_BOT_COUNT=100

# false — webhook: make load-k6; polling: make load-k6-polling (/stats); only bots table
# true  — draw load: make load-k6-run / load-k6-run-polling; seeds players table
LOAD_SEED_DRAW_ENTRANTS=false

# Required when LOAD_SEED_DRAW_ENTRANTS=true (>=2 for /run then /loser in same chat)
LOAD_PLAYERS_PER_CHAT=2

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

REGISTRATION_ENABLED=true
LOG_INBOUND_COMMANDS=false

LOAD_HTTP_PORT=8080
LOAD_APP_PORT=8000
# Metrics: Makefile METRICS_PORT (default 8001), SCRAPE_INTERVAL (default 15s)

# Fixed vps-sim internals (postgres init + app + seed; do not change)
# DB_URL is derived by compose.load.yml from POSTGRES_* — do not add it here.
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_DB=friends_bot

# Technical ID offsets (shared by seed + k6; keep in sync, usually leave unchanged)
LOAD_BOT_ID_START=1000000
LOAD_BOT_OWNER_ID=1
LOAD_CHAT_ID_BASE=10000000
LOAD_USER_ID_BASE=100000
