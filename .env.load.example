# Copy to .env.load and fill secrets before: make load-up
#
# --- AB polling (lock vs claim, same BOT_MODE=polling) ---
#   NGINX_ENABLED=0
#   BOT_MODE=polling
#   Rebuild from main, run; then checkout workers, make load-down-v load-build load-up
#
# --- AB webhook (registry vs db-first ingress) ---
#   NGINX_ENABLED=1
#   BOT_MODE=webhook
#   k6 → http://localhost:LOAD_HTTP_PORT
#
# Image tag: rebuild after branch switch (make docker-build IMAGE=... load-build)
APP_IMAGE=friends-bot-service:local

NGINX_ENABLED=1
BOT_MODE=webhook
WORKER_COUNT=1

LOAD_HTTP_PORT=8080
LOAD_APP_PORT=8000

VPS_SIM_CPUS=1
VPS_SIM_MEMORY=2g

POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_DB=friends_bot

ENCRYPTION_KEY=change-me-32-bytes-min-secret!!
MASTER_TOKEN=0000000000:REPLACE_WITH_MASTER_BOT_TOKEN
WEBHOOK_BASE_URL=http://localhost:8080
WEBHOOK_SECRET_TOKEN=load-test-webhook-secret

REGISTRATION_ENABLED=true
LOG_INBOUND_COMMANDS=false

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
